# NVIDIA API Key for embeddings (llama-nemotron-embed-1b-v2)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NVIDIA API Base URL for embeddings
NVIDIA_EMBED_BASE_URL=https://integrate.api.nvidia.com/v1

# NVIDIA Embedding Model
NVIDIA_EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2

# LLM Configuration (uses NVIDIA NIM API – OpenAI-compatible)
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# RAG Configuration
CHUNK_SIZE=600
CHUNK_OVERLAP=100
TOP_K=5

# Vector DB path
FAISS_INDEX_PATH=data/faiss_index
